@echo off
if /I "%~1"=="-qt" goto qt
if /I "%~1"=="-core" goto core
if /I "%~1"=="-ui" goto ui
if /I "%~1"=="-reset" goto reset
if /I "%~1"=="-uninstall" goto uninstall
if /I "%~1"=="-ver" goto ver
if /I "%~1"=="-help" goto help
if "%~1"=="" goto menu

echo [!] Error: Unknown command '%~1'
echo.
goto help

:menu
powershell -NoProfile -ExecutionPolicy Bypass -EncodedCommand 
if %errorlevel% EQU 5 exit /b
if %errorlevel% EQU 4 goto uninstall
if %errorlevel% EQU 3 goto reset
if %errorlevel% EQU 2 goto core
if %errorlevel% EQU 1 goto ui
if %errorlevel% EQU 0 goto qt
goto menu

:qt
schtasks /run /tn "\Detaroxz\AutoDM\AutoDM - Quick Toggle" >nul 2>&1
exit /b

:core
call "C:\Program Files\Detaroxz\AutoDM\AutoDM-Core.cmd" CLI
exit /b

:ui
start "" "C:\Program Files\Detaroxz\AutoDM\AutoDM-Core.cmd" UI
exit /b

:reset
echo Resetting AutoDM Scheduled Tasks...
powershell -NoProfile -ExecutionPolicy Bypass -EncodedCommand 
exit /b

:uninstall
start "" "C:\Program Files\Detaroxz\AutoDM\Uninstall.cmd"
exit /b

:ver
echo AutoDM v1.4.1
exit /b

:help
echo ========================================
echo   AutoDM v1.4.1 by detaroxz
echo ========================================
echo.
echo Usage: autodm [command]
echo.
echo Commands:
echo   -qt        : Instantly toggles the current theme
echo   -core      : Opens the inline CLI Core
echo   -ui        : Opens the full graphical Core
echo   -reset     : Resets the Task Scheduler triggers
echo   -uninstall : Uninstalls AutoDM completely
echo   -ver       : Displays the version
echo   -help      : Displays this menu
echo.
exit /b
